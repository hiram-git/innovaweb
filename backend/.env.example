APP_NAME=InnovaWeb
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Panama
APP_URL=http://innovaweb-api.test

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────────
# SQL SERVER — Conexión a la base de datos del ERP (Clarion)
# ─────────────────────────────────────────────────────────────────
# Instancia nombrada (SQL Express): DB_HOST=PC-NAME\SQLEXPRESS, DB_PORT vacío
# Puerto fijo:                      DB_HOST=127.0.0.1,           DB_PORT=1433
DB_CONNECTION=sqlsrv
DB_HOST=NOMBRE_PC\SQLEXPRESS
DB_PORT=
DB_DATABASE=NOMBRE_BASE_DE_DATOS
DB_USERNAME=usuario_sql
DB_PASSWORD=
DB_ENCRYPT=0
DB_TRUST_SERVER_CERTIFICATE=true

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=innovaweb_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="facturacion@tuempresa.com"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=localhost,innovaweb.test,innovaweb-api.test

# ─────────────────────────────────────────────────────────────────
# FACTURACIÓN ELECTRÓNICA
# ─────────────────────────────────────────────────────────────────
FE_AMBIENTE=sandbox

TFHKA_WSDL_SANDBOX=https://demows.epak.com.pa/WsIntegracion_GT/WsIntegracion.asmx?WSDL
TFHKA_WSDL_PROD=https://ws.epak.com.pa/WsIntegracion_GT/WsIntegracion.asmx?WSDL

DIGIFACT_API_SANDBOX=https://api-pruebas.digifact.com.pa
DIGIFACT_API_PROD=https://api.digifact.com.pa

VITE_APP_NAME="${APP_NAME}"
